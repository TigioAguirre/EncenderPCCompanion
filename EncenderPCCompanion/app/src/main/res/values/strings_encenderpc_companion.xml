<?xml version="1.0" encoding="utf-8"?>
<!--
  Android fusiona automáticamente TODOS los archivos .xml que estén
  dentro de res/values/, sin importar el nombre del archivo. Así que
  con copiar este archivo tal cual a app/src/main/res/values/ ya
  alcanza — no hace falta pegar nada a mano dentro de tu strings.xml
  existente.
-->
<resources>
