<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BandColorReact" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/bg_card</item>
        <item name="colorPrimaryDark">@color/bg_app</item>
        <item name="colorAccent">@color/colorAccent</item>
        <!-- Manrope: geométrica y redondeada, misma familia visual que la
             MiSans de Mi Fitness/Mi Band. Se aplica a nivel de tema para
             que toda vista que no defina su propia fuente la herede. -->
        <item name="android:fontFamily">@font/font_manrope</item>
        <item name="android:windowBackground">@color/bg_app</item>
    </style>

    <!-- Se añade parent="" para evitar que Android busque un estilo base inexistente llamado "Text" -->
    <style name="Text.Body" parent="">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/font_manrope</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Text.Caption" parent="">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">@font/manrope_semibold</item>
    </style>

    <!-- Título de sección/tarjeta: peso alto, como los encabezados de Mi Band -->
    <style name="Text.Title" parent="">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/manrope_bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Subtítulo/ayuda bajo un título -->
    <style name="Text.Subtitle" parent="">
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">@font/font_manrope</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Button.Primary" parent="Widget.AppCompat.Button">
        <item name="android:backgroundTint">@color/colorAccent</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:fontFamily">@font/manrope_semibold</item>
        <item name="android:textAllCaps">false</item>
        <!-- Se elimina cornerRadius porque no es compatible directamente con AppCompat -->
    </style>

    <!-- Botón secundario: mismo look que Button.Primary pero sin relleno,
         para acciones que no deben competir visualmente con la acción
         principal (heurística de jerarquía visual / estética minimalista) -->
    <style name="Button.Secondary" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_card_outlined</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/manrope_semibold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Button.Text" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:textColor">@color/colorAccent</item>
        <item name="android:fontFamily">@font/manrope_semibold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Línea separadora delgada dentro de una tarjeta, entre filas -->
    <style name="Divider" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/divider</item>
        <item name="android:layout_marginVertical">2dp</item>
    </style>
</resources>