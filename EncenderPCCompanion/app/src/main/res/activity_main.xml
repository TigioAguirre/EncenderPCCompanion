<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <!-- Cabecera: título + acceso directo a ayuda/tutorial siempre visible
             (heurística 10 - Ayuda y documentación / heurística 6 -
             Reconocer antes que recordar: el usuario no tiene que acordarse
             de que el tutorial existe, el acceso está siempre a la vista) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/space_md">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/title_main"
                android:textSize="22sp"
                android:fontFamily="@font/manrope_extrabold"
                android:textColor="@color/text_primary" />

            <ImageButton
                android:id="@+id/btnPcCompanion"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_card_outlined"
                android:src="@drawable/ic_pc_outline"
                android:padding="8dp"
                android:contentDescription="@string/content_desc_pc_companion" />

            <ImageButton
                android:id="@+id/btnHelp"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_card_outlined"
                android:src="@drawable/ic_help_outline"
                android:padding="8dp"
                android:contentDescription="@string/content_desc_help" />
        </LinearLayout>

        <!-- Interruptor maestro: la acción más frecuente y reversible,
             siempre arriba del todo (heurística 3 - Control y libertad) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_md"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/space_md">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/switchLabel"
                        style="@style/Text.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/switch_service_enabled" />

                    <TextView
                        android:id="@+id/switchSubtitle"
                        style="@style/Text.Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/switch_subtitle_on" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchServiceEnabled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tarjeta de estado: reemplaza los 4 botones sueltos + el bloque de
             texto plano que había antes (estaban duplicados y no eran
             consistentes entre sí). Reutiliza los mismos íconos, textos y
             chips OK/Falta que el tutorial (heurística 4 - Consistencia y
             estándares) y muestra siempre qué falta y un botón "Conceder"
             junto a cada ítem (heurística 1 - Visibilidad del estado del
             sistema, heurística 9 - Ayudar a reconocer y resolver errores) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_md"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_md">

                <TextView
                    style="@style/Text.Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/main_status_card_title" />

                <TextView
                    android:id="@+id/textStatusSummary"
                    style="@style/Text.Subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="@dimen/space_sm"
                    android:text="@string/main_status_card_subtitle" />

                <!-- Fila 1: Acceso a notificaciones -->
                <include
                    android:id="@+id/rowNotification"
                    layout="@layout/item_status_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <View style="@style/Divider" />

                <!-- Fila 2: Superposición de pantalla -->
                <include
                    android:id="@+id/rowOverlay"
                    layout="@layout/item_status_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <View style="@style/Divider" />

                <!-- Fila 3: Exención de batería -->
                <include
                    android:id="@+id/rowBattery"
                    layout="@layout/item_status_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <View style="@style/Divider" />

                <!-- Fila 4: Notificaciones del sistema (Android 13+) -->
                <include
                    android:id="@+id/rowPostNotifications"
                    layout="@layout/item_status_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_md"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_md">

                <TextView
                    style="@style/Text.Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/url_section_title" />

                <TextView
                    style="@style/Text.Subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="@dimen/space_sm"
                    android:text="@string/url_section_subtitle" />

                <EditText
                    android:id="@+id/editTriggerUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/font_manrope"
                    android:hint="@string/url_input_hint"
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/colorAccent"
                    android:inputType="textUri"
                    android:maxLines="3"
                    android:autofillHints="" />

                <!-- Validación en tiempo real: el error aparece apenas se
                     escribe algo inválido, no solo al intentar guardar
                     (heurística 5 - Prevención de errores) -->
                <TextView
                    android:id="@+id/textUrlInlineError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/error_url_invalid"
                    android:textColor="@color/state_danger"
                    android:textSize="12sp"
                    android:fontFamily="@font/manrope_semibold"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnSaveUrl"
                    style="@style/Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/btn_save_url" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Acceso secundario, discreto, a repetir el tutorial completo en
             cualquier momento (heurística 10 - Ayuda y documentación) -->
        <Button
            android:id="@+id/btnViewTutorialAgain"
            style="@style/Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:text="@string/btn_view_tutorial_again" />

    </LinearLayout>
</ScrollView>
